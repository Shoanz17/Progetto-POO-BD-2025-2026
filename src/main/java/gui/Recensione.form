<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.Recensione">
  <grid id="27dc6" binding="recensionePanel" layout-manager="GridLayoutManager" row-count="5" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="ab6c" class="javax.swing.JButton" binding="rilasciaRecensioneButton" default-binding="true">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="18"/>
          <text value="Rilascia recensione"/>
        </properties>
      </component>
      <component id="fd58c" class="javax.swing.JSpinner" binding="spinnerVoto">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
      </component>
      <component id="fbab5" class="javax.swing.JLabel" binding="testoVoto">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="18"/>
          <text value="Aggiungi voto da 0 a 100"/>
        </properties>
      </component>
      <component id="eb64d" class="javax.swing.JLabel" binding="testoNomeGioco">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="20" style="1"/>
          <text value="[NomeGioco]"/>
        </properties>
      </component>
      <component id="4c6cb" class="javax.swing.JLabel" binding="testoDescrizione">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="18"/>
          <text value="Descrizione:"/>
        </properties>
      </component>
      <scrollpane id="401b5">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="2762c" class="javax.swing.JTextArea" binding="textAreaDescrizione">
            <constraints/>
            <properties>
              <columns value="1"/>
              <font size="18"/>
              <lineWrap value="true"/>
              <rows value="7"/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <component id="5766d" class="javax.swing.JLabel">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="(Max 500 caratteri)"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
